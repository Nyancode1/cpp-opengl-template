{
  "version": "0.2.0",
  "configurations": [
    {
      // A) 단일 파일 g++ 모드
      "name": "Run: single-file (g++)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${fileDirname}/${fileBasenameNoExtension}.exe",
      "cwd": "${fileDirname}",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
      "preLaunchTask": "Build: single-file (g++)"
    },
    {
      // B) 외부 라이브러리(CMake) 모드
      "name": "Run: CMake target (demo)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/demo.exe",
      "cwd": "${workspaceFolder}/build",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
      "preLaunchTask": "CMake: build (ninja)",
      "environment": [
        {
          "name": "PATH",
          "value": "${workspaceFolder}/build;${env:PATH}"
        }
      ]
    }
  ]
}
